# MarketX Backend Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=marketx
DATABASE_URL=
DATABASE_SYNC=true
DATABASE_LOAD=true

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379
CACHE_MAX_MEMORY_ITEMS=1000
CACHE_ENABLED=true

# ============================================
# RabbitMQ Configuration
# ============================================
AMQP_URL=amqp://guest:guest@localhost:5672
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ============================================
# Authentication & Security
# ============================================
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_CLOUDFRONT_URL=https://your-cloudfront-distribution.cloudfront.net

# AWS Backup Configuration
AWS_S3_BACKUP_BUCKET=your-backup-bucket-name
AWS_S3_BACKUP_PREFIX=postgres-backups

# ============================================
# Payment Processing (Stripe)
# ============================================
STRIPE_API_KEY=sk_test_your-stripe-secret-key
PLATFORM_FEE_PERCENT=10

# ============================================
# Email Service (SendGrid)
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# Rate Limiting Configuration
# ============================================
# Authentication Rate Limits (very strict)
RATE_LIMIT_AUTH_LIMIT=5
RATE_LIMIT_AUTH_WINDOW=900000

# Login Rate Limits
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_WINDOW=900000

# Registration Rate Limits
RATE_LIMIT_REGISTER_LIMIT=3
RATE_LIMIT_REGISTER_WINDOW=3600000

# Password Reset Rate Limits
RATE_LIMIT_PASSWORD_LIMIT=3
RATE_LIMIT_PASSWORD_WINDOW=3600000

# General API Rate Limits
RATE_LIMIT_API_LIMIT=100
RATE_LIMIT_API_WINDOW=900000

# Upload Rate Limits
RATE_LIMIT_UPLOAD_LIMIT=10
RATE_LIMIT_UPLOAD_WINDOW=3600000

# Transaction Rate Limits
RATE_LIMIT_TRANSACTION_LIMIT=20
RATE_LIMIT_TRANSACTION_WINDOW=60000

# Payment Rate Limits
RATE_LIMIT_PAYMENT_LIMIT=10
RATE_LIMIT_PAYMENT_WINDOW=3600000

# Search Rate Limits
RATE_LIMIT_SEARCH_LIMIT=30
RATE_LIMIT_SEARCH_WINDOW=300000

# Export/Download Rate Limits
RATE_LIMIT_EXPORT_LIMIT=5
RATE_LIMIT_EXPORT_WINDOW=3600000

# ============================================
# Request Size Limits
# ============================================
MAX_JSON_SIZE=10mb
MAX_URLENCODED_SIZE=10mb
MAX_FILE_SIZE=50mb

# ============================================
# Security Configuration
# ============================================
# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Security Headers
HSTS_MAX_AGE=max-age=31536000; includeSubDomains
CSP_POLICY=default-src 'self'

# IP Blocking/Whitelisting
BLOCKED_IPS=
IP_WHITELIST=
ENABLE_IP_WHITELIST=false

# ============================================
# Pact Contract Testing (Optional)
# ============================================
PACT_BROKER_URL=http://localhost:9292
PACT_BROKER_TOKEN=
PACT_BROKER_USERNAME=
PACT_BROKER_PASSWORD=
PROVIDER_BASE_URL=http://localhost:3000
GIT_COMMIT=local
GIT_BRANCH=local
PACT_TEST_AUTH_TOKEN=test-auth-token-for-pact-testing
WIP_PACTS_SINCE=2026-01-01
PACT_LOG_LEVEL=info
CI=false

# Security Configuration
# ======================

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://marketx.example.com

# IP Blocking/Whitelisting
# Leave empty to disable, or add comma-separated IPs
BLOCKED_IPS=
IP_WHITELIST=
ENABLE_IP_WHITELIST=false

# HSTS (HTTP Strict Transport Security)
HSTS_MAX_AGE=max-age=31536000; includeSubDomains

# Content Security Policy
CSP_POLICY=default-src 'self'

# Node Environment
NODE_ENV=development
# Logging Configuration
# ======================

# Log levels: error, warn, info, debug
LOG_LEVEL=info

# Database Logging (development only)
DB_LOGGING=true

COINGECKO_API_KEY=your_key_here   # optional, increases rate limits

# Multi-Currency Configuration
# =============================
# Exchange rates are fetched from Frankfurter API (no key required)
# Rates are cached in Redis and refreshed every 4 hours
# All prices stored in USD as base currency

# Image Upload Configuration
# ===========================

# Storage Provider: 'local' or 's3'
STORAGE_PROVIDER=local

# Local Storage Configuration
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:3000

# AWS S3 Configuration (required if STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_CLOUDFRONT_URL=https://your-cloudfront-domain.cloudfront.net

# Image Processing Configuration
MAX_IMAGE_SIZE_MB=5
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# Image Variant Sizes (in pixels)
THUMBNAIL_WIDTH=200
THUMBNAIL_HEIGHT=200
THUMBNAIL_QUALITY=80

MEDIUM_WIDTH=800
MEDIUM_HEIGHT=800
MEDIUM_QUALITY=85

ORIGINAL_MAX_WIDTH=2048
ORIGINAL_MAX_HEIGHT=2048
ORIGINAL_QUALITY=90

# Coupon Configuration
# ====================

# Default coupon code format (optional prefix)
COUPON_CODE_PREFIX=

# Maximum percentage discount allowed (0-100)
MAX_PERCENTAGE_DISCOUNT=100

# Maximum fixed discount amount
MAX_FIXED_DISCOUNT=10000

# Default coupon validity period in days (if not specified)
DEFAULT_COUPON_VALIDITY_DAYS=30

# ── Email Service (SendGrid) ─────────────────────────────────────────────────

# SendGrid API key (obtain from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# The "From" address for all transactional emails
EMAIL_FROM=noreply@marketx.com

# Shared secret to verify SendGrid inbound webhook signatures
SENDGRID_WEBHOOK_SECRET=your_sendgrid_webhook_secret

# Public base URL of the application (used to build reset/tracking links in emails)
APP_URL=https://marketx.example.com

# ── Typesense Search Configuration ──────────────────────────────────────────────
# Typesense server configuration for search (typo-tolerant search)
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your_typesense_api_key

# ── Stripe Payment Configuration ─────────────────────────────────────────────────
# Stripe API key for payment processing (obtain from https://dashboard.stripe.com/apikeys)
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Platform fee percentage (e.g., 10 = 10%)
PLATFORM_FEE_PERCENT=10
