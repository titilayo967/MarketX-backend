{
  "name": "marketx-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/app.module.ts\" \"src/users/users.service.ts\" \"src/job-processing/**/*.ts\" \"src/email/email.module.ts\" \"src/email/email.processor.ts\" \"src/email/email.service.ts\" \"src/media/media.controller.ts\" \"src/media/media.jobs.ts\" \"src/media/media.module.ts\" \"src/media/media.processor.ts\" \"src/media/media.service.ts\" \"src/media/services/image-processing.service.ts\" \"src/products/product-images.controller.ts\" \"src/recommendation/recommendation.controller.ts\" \"src/recommendation/recommendation.jobs.ts\" \"src/recommendation/recommendation.module.ts\" \"src/recommendation/recommendation.processor.ts\" \"src/recommendation/recommendation.scheduler.ts\" \"src/recommendation/recommendation.service.ts\" \"src/messaging/**/*.ts\" \"README.md\" \"package.json\" \"docker-compose.yml\" \".github/workflows/*.yml\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:issues": "eslint \"src/job-processing/queue.constants.ts\" \"src/job-processing/queue.constants.spec.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit --pretty false",
    "typecheck:issues": "tsc --project tsconfig.issues.json --noEmit --pretty false",
    "test": "jest",
    "test:issues": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --runInBand --runTestsByPath src/job-processing/queue.constants.spec.ts",
    "pr:check": "npm run lint:issues && npm run typecheck:issues && npm run test:issues",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:coverage:check": "jest --coverage --ci",
    "test:coverage:auth": "jest --coverage --testPathPattern='src/auth/' --ci",
    "test:coverage:payments": "jest --coverage --testPathPattern='src/payments/' --ci",
    "test:coverage:orders": "jest --coverage --testPathPattern='src/orders/' --ci",
    "test:coverage:escrow": "jest --coverage --testPathPattern='src/escrowes/' --ci",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
"test:smoke": "jest --testPathPattern=module-wiring.smoke.spec.ts --runInBand",
    "security:scan": "node security/zap/security-tester.js",
    "security:docker": "docker compose --profile security-test up -d",
    "security:zap": "docker compose run --rm zap",
    "security:zap-full": "docker compose run --rm zap-full",
    "security:report": "node security/zap/security-tester.js --report-only",
    "security:ci": "docker compose --profile security-test up -d && sleep 10 && docker compose run --rm security-test-runner",
    "pact:verify": "ts-node pact/provider-verifier.ts",
    "pact:verify:consumer": "ts-node pact/provider-verifier.ts",
    "pact:test": "npm run build && npm run pact:verify",
    "pact:ci": "npm run build && npm run pact:verify",
    "mutation": "stryker run",
    "mutation:payments": "stryker run --mutate \"src/payments/payments.service.ts\"",
    "mutation:orders": "stryker run --mutate \"src/orders/orders.service.ts\"",
    "mutation:shipping": "stryker run --mutate \"src/shipping/shipping.service.ts\"",
    "mutation:escrow": "stryker run --mutate \"src/escrow/escrow.service.ts\"",
    "mutation:transactions": "stryker run --mutate \"src/transactions/transactions.service.ts\"",
    "mutation:refunds": "stryker run --mutate \"src/refunds/refunds.service.ts\"",
    "mutation:wallet": "stryker run --mutate \"src/wallet/wallet.service.ts\"",
    "docs:generate": "ts-node scripts/generate-api-docs.ts",
    "docs:render": "redoc-cli bundle docs/api/openapi.json -o docs/api/index.html",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:report": "npm audit --json > security/audit-report.json || true",
    "doctor": "bash scripts/doctor.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sendgrid/mail": "^8.1.6",
    "@stellar/stellar-sdk": "^14.4.3",
    "@types/bull": "^3.15.9",
    "@types/cache-manager": "^4.0.6",
    "@types/compression": "^1.8.1",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.14.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis": "^2.1.0",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "crypto": "^1.0.1",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.7.0",
    "geoip-lite": "^1.4.3",
    "handlebars": "^4.7.8",
    "ioredis": "^5.6.1",
    "json2csv": "^6.0.0-alpha.2",
    "multer": "^2.0.1",
    "nest-winston": "^1.9.0",
    "nestjs-i18n": "^10.5.1",
    "node-geocoder": "^3.29.0",
    "otplib": "^13.4.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.17.1",
    "pg": "^8.16.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.0",
    "stripe": "^21.0.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.25",
    "typesense": "^3.0.4",
    "uuid": "^9.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.3",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@nestjs/websockets": "^11.1.3",
    "@pact-foundation/pact": "^16.3.0",
    "@pact-foundation/pact-node": "^10.18.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^5.0.2",
    "@types/connect": "^3.4.38",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.19.15",
    "@types/send": "^0.17.5",
    "@types/sharp": "^0.32.0",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "redoc-cli": "^0.13.21"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
  "node_modules/(?!(@scure|@noble|otplib|@otplib)/)"
],
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      ".module.ts$",
      ".entity.ts$",
      ".dto.ts$",
      ".interface.ts$",
      ".types.ts$",
      ".decorator.ts$",
      ".guard.ts$",
      ".strategy.ts$",
      ".subscriber.ts$",
      "index.ts$"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      },
      "./src/auth/": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./src/payments/": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./src/orders/": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./src/escrowes/": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node"
  }
}
